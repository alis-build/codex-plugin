{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/ensure-alis-rule.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/route-alis-triggers.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*(LoadSkill|SpecIt)$",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/inject-skill-session-id.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
